;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="EpicCookingGame"
run/main_scene="uid://bh8xgnqcc23o5"
config/features=PackedStringArray("4.4", "Forward Plus")
run/max_fps=60
config/icon="res://icon.svg"

[autoload]

Global="*res://Global.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720

[editor]

movie_writer/movie_file="H:/epiccookinggame/Movie/Gamepplay.avi"

[file_customization]

folder_colors={
"res://Assets/": "red",
"res://Fonts/": "orange",
"res://Movie/": "teal",
"res://Player/": "yellow",
"res://World/": "green"
}

